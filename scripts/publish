#!/usr/bin/env bash
# Deploy to Cloudflare Pages and post deployment URL.
#
# Usage: scripts/publish
#
# Required environment variables:
#   CLOUDFLARE_API_TOKEN     - Cloudflare API token with Pages edit permission
#   CLOUDFLARE_ACCOUNT_ID    - Cloudflare account ID
#   CLOUDFLARE_PAGES_PROJECT - Cloudflare Pages project name
#   DEPLOY_BRANCH            - Branch name for the deployment
#
# Optional environment variables:
#   GITHUB_STEP_SUMMARY      - Path to GitHub Actions step summary file
#   GITHUB_EVENT_NAME        - "pull_request" to enable PR comment
#   PR_NUMBER                - PR number (required when GITHUB_EVENT_NAME=pull_request)
#   GH_TOKEN                 - GitHub token for posting PR comments

set -euo pipefail

# ---------------------------------------------------------------------------
# Validate required env vars
# ---------------------------------------------------------------------------
for var in CLOUDFLARE_API_TOKEN CLOUDFLARE_ACCOUNT_ID CLOUDFLARE_PAGES_PROJECT DEPLOY_BRANCH; do
  if [[ -z "${!var:-}" ]]; then
    echo "Error: $var is not set" >&2
    exit 1
  fi
done

# ---------------------------------------------------------------------------
# Deploy to Cloudflare Pages
# ---------------------------------------------------------------------------
echo "Deploying public/ to Cloudflare Pages (branch: $DEPLOY_BRANCH)..." >&2

deploy_output=$(npx wrangler@3 pages deploy public \
  --project-name="$CLOUDFLARE_PAGES_PROJECT" \
  --branch="$DEPLOY_BRANCH" 2>&1)

echo "$deploy_output" >&2

# Extract deployment URL from wrangler output.
# Wrangler prints a line like: "✨ Deployment complete! Take a peek over at https://..."
deployment_url=$(echo "$deploy_output" | grep -oP 'https://[a-zA-Z0-9._-]+\.pages\.dev\b' | tail -1)

if [[ -z "$deployment_url" ]]; then
  echo "Error: could not extract deployment URL from wrangler output" >&2
  exit 1
fi

echo "Deployed to: $deployment_url" >&2

# ---------------------------------------------------------------------------
# Write to GitHub Actions step summary (if available)
# ---------------------------------------------------------------------------
if [[ -n "${GITHUB_STEP_SUMMARY:-}" ]]; then
  {
    echo "### Deployment URL"
    echo "$deployment_url"
  } >> "$GITHUB_STEP_SUMMARY"
fi

# ---------------------------------------------------------------------------
# Post PR comment (pull_request events only)
# ---------------------------------------------------------------------------
if [[ "${GITHUB_EVENT_NAME:-}" == "pull_request" && -n "${PR_NUMBER:-}" ]]; then
  comment_body="## Cloudflare Pages Deployment

🚀 Preview: $deployment_url"

  # Find existing bot comment to update
  existing_comment_id=$(gh api "repos/{owner}/{repo}/issues/$PR_NUMBER/comments" \
    --jq '.[] | select(.user.login == "github-actions[bot]" or .user.type == "Bot") |
          select(.body | contains("Cloudflare Pages Deployment")) | .id' 2>/dev/null | tail -1 || true)

  if [[ -n "$existing_comment_id" ]]; then
    gh api "repos/{owner}/{repo}/issues/comments/$existing_comment_id" \
      --method PATCH --field body="$comment_body" > /dev/null
    echo "Updated existing PR comment" >&2
  else
    gh api "repos/{owner}/{repo}/issues/$PR_NUMBER/comments" \
      --method POST --field body="$comment_body" > /dev/null
    echo "Posted new PR comment" >&2
  fi
fi

# Output the deployment URL
echo "$deployment_url"
